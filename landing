<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Linktrack.ink - Link Analytics for Creators</title>
  <meta name="description" content="Track clicks on your link-in-bio links. Know which links actually work.">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --bg: #0a0a0b; --surface: #141416; --surface-2: #1c1c1f; --text: #fff; --text-2: #a1a1aa; --primary: #22c55e; --primary-hover: #16a34a; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
    .container { max-width: 800px; margin: 0 auto; padding: 0 1.5rem; }
    header { padding: 1.5rem 0; display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 1.5rem; font-weight: 700; }
    .logo span { color: var(--primary); }
    .nav a { color: var(--text-2); text-decoration: none; margin-left: 1.5rem; }
    .nav a:hover { color: var(--text); }
    .hero { text-align: center; padding: 5rem 0; }
    .hero h1 { font-size: 3rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.1; }
    .hero h1 span { color: var(--primary); }
    .hero p { font-size: 1.25rem; color: var(--text-2); max-width: 500px; margin: 0 auto 2rem; }
    .btn { display: inline-block; background: var(--primary); color: #000; padding: 1rem 2rem; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 1.1rem; transition: background 0.2s; }
    .btn:hover { background: var(--primary-hover); }
    .btn-secondary { background: var(--surface-2); color: var(--text); }
    .features, .pricing, .how-it-works { padding: 4rem 0; }
    .section-title { text-align: center; font-size: 2rem; margin-bottom: 3rem; }
    .feature-grid, .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; }
    .feature, .price-card { background: var(--surface); padding: 2rem; border-radius: 12px; text-align: center; }
    .feature-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .feature h3, .price-card h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
    .feature p, .price-card p { color: var(--text-2); }
    .price-card.popular { border: 2px solid var(--primary); }
    .price { font-size: 3rem; font-weight: 700; color: var(--primary); }
    .price span { font-size: 1rem; color: var(--text-2); }
    .price-card ul { list-style: none; margin: 1.5rem 0; text-align: left; }
    .price-card li { padding: 0.5rem 0; color: var(--text-2); }
    .price-card li::before { content: "✓ "; color: var(--primary); }
    .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; text-align: center; }
    .step-num { width: 40px; height: 40px; background: var(--primary); color: #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; margin: 0 auto 1rem; }
    footer { padding: 3rem 0; text-align: center; color: var(--text-2); }
    @media (max-width: 600px) { .hero h1 { font-size: 2rem; } .steps { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div class="logo">linktrack<span>.ink</span></div>
      <nav class="nav">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="https://linktrack.ink">Sign In</a>
      </nav>
    </header>
    
    <section class="hero">
      <h1>Stop Guessing.<br><span>Start Tracking.</span></h1>
      <p>The link-in-bio analytics tool that shows you exactly which links your followers are clicking.</p>
      <a href="https://linktrack.ink" class="btn">Start Free</a>
    </section>
    
    <section class="features" id="features">
      <h2 class="section-title">Why Creators Need Linktrack</h2>
      <div class="feature-grid">
        <div class="feature">
          <div class="feature-icon">👁️</div>
          <h3>See Every Click</h3>
          <p>Know exactly how many people click each link in your bio.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">📊</div>
          <h3>Track Performance</h3>
          <p>Identify your top-performing content and double down on what works.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">⚡</div>
          <h3>One-Minute Setup</h3>
          <p>Just replace your links with tracking URLs. No code required.</p>
        </div>
      </div>
    </section>
    
    <section class="how-it-works">
      <h2 class="section-title">How It Works</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Create Your Links</h3>
          <p>Add the links you want to track in your dashboard.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Update Your Bio</h3>
          <p>Replace your links with your linktrack.ink URLs.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Watch the Data</h3>
          <p>See exactly who's clicking and when.</p>
        </div>
      </div>
    </section>
    
    <section class="pricing" id="pricing">
      <h2 class="section-title">Simple Pricing</h2>
      <div class="pricing-grid">
        <div class="price-card">
          <h3>Free</h3>
          <div class="price">$0<span>/mo</span></div>
          <ul>
            <li>50 clicks/month</li>
            <li>5 links</li>
            <li>Basic analytics</li>
          </ul>
          <a href="https://linktrack.ink" class="btn btn-secondary">Get Started</a>
        </div>
        <div class="price-card popular">
          <h3>Pro</h3>
          <div class="price">$9<span>/mo</span></div>
          <ul>
            <li>Unlimited clicks</li>
            <li>Unlimited links</li>
            <li>Advanced analytics</li>
            <li>Priority support</li>
          </ul>
          <a href="https://linktrack.ink" class="btn">Upgrade Now</a>
        </div>
      </div>
    </section>
    
    <footer>
      <p>© 2026 linktrack.ink — Made for creators, by creators.</p>
    </footer>
  </div>
</body>
</html>
